# Claude Code session artifacts (project-local)
.claude/local/
.claude/worktrees/
.omc/

# Wiki drafts area (only matches a vault embedded in the repo; harmless
# elsewhere). Pending-review concept articles should not be committed.
Wiki/.drafts/

# Secrets — defense in depth. The user's API keys live OUTSIDE the repo
# at ~/.config/paperwiki/, but if someone ever drops a .env or
# secrets.* into the project tree, we never want to commit it.
.env
.env.*
*.env
secrets/
secrets.*
*.secret
.secrets/

# Per-user paperwiki config (if anyone copies it into the project tree)
.paperwiki/

# Internal devlog & planning docs — NOT shipped to end users.
# These are author-only notes (multi-thousand-line plans, in-progress
# todo lists). End users who /plugin install paper-wiki@paper-wiki get
# the whole repo cloned into their cache; trimming these keeps that
# cache smaller and avoids confusing user-facing surface area.
tasks/plan.md
tasks/todo.md
tests/fixtures/synthetic_vault_100/.graph/
